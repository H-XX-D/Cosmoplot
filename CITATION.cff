    given-names: Todd
    alias: ">X<"
version: 0.1.0
date-released: 2026-07-05
license: MIT
url: "https://cosmoplot.vercel.app"
repository-code: "https://github.com/H-XX-D/Cosmoplot"
keywords:
  - exoplanets
  - astronomy
  - astrophysics
  - data-visualization
  - NASA Exoplanet Archive
  - JWST
  - three.js
